{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CKB-PoP Participation Badge Metadata",
  "description": "Immutable metadata for a participation badge or SBT",
  "type": "object",
  "required": ["protocol", "version", "scope_id", "issuer", "issued_at_block"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "ckb-pop",
      "description": "Protocol identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Schema version"
    },
    "scope_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique issuance scope identifier (event, hackathon, program, course, campaign, bounty, or membership)"
    },
    "scope_kind": {
      "type": "string",
      "enum": ["event", "hackathon", "program", "course", "campaign", "bounty", "membership", "custom"],
      "description": "Logical type of participation scope"
    },
    "participation_mode": {
      "type": "string",
      "enum": ["in-person", "online", "hybrid", "async"],
      "description": "How the participation was earned"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "Legacy alias for scope_id used by older reference clients"
    },
    "issuer": {
      "type": "string",
      "pattern": "^(ckb1|ckt1)", 
      "description": "Scope issuer's CKB address"
    },
    "issued_at_block": {
      "type": "integer",
      "minimum": 0,
      "description": "Block number when badge was minted"
    },
    "proof_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "Opaque hash of off-chain participation proof (not interpreted by chain)"
    }
  },
  "additionalProperties": false
}
