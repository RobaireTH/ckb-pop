{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CKB-PoP Scope Anchor Metadata",
  "description": "Immutable metadata for an issuance scope anchor cell",
  "type": "object",
  "required": ["scope_id", "creator", "metadata_hash"],
  "properties": {
    "scope_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique issuance scope identifier"
    },
    "scope_kind": {
      "type": "string",
      "enum": ["event", "hackathon", "program", "course", "campaign", "bounty", "membership", "custom"],
      "description": "Logical type of scope being anchored"
    },
    "creator": {
      "type": "string",
      "pattern": "^(ckb1|ckt1)",
      "description": "Scope creator's CKB address"
    },
    "creator_address": {
      "type": "string",
      "pattern": "^(ckb1|ckt1)",
      "description": "Legacy alias for creator"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "Legacy alias for scope_id"
    },
    "metadata_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "Hash of off-chain scope metadata (name, description, rules, etc.)"
    },
    "created_at_block": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional block number when anchor was created"
    }
  },
  "additionalProperties": false
}
